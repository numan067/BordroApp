<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/layout/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bordro Uygulaması"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btnMaas"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Maaş Hesaplama"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3F51B5"/>

        <Button
            android:id="@+id/btnFark"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Fark Hesaplama"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3F51B5"/>

        <Button
            android:id="@+id/btnSosyal"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Sosyal Haklar"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3F51B5"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#D1D1D1"
            android:layout_marginVertical="20dp"/>

        <Button
            android:id="@+id/btnEnflasyon"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Bileşik Enflasyon"
            android:textSize="16sp"
            android:backgroundTint="#E64A19"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="bordro.pages.dev"
            android:layout_marginTop="30dp"
            android:textColor="#757575"
            android:textSize="12sp"/>

    </LinearLayout>
</ScrollView>
